# HELPERS (zshenv is loaded before zshrc, so needs its own)
function _has { hash "${1}" 2> /dev/null }
function _is_macos { [[ "$OSTYPE" == darwin* ]] }
function _source_if_exists { [ -f "${1}" ] && source "${1}" "${2}" }
function _source_first { for f in "$@"; do [ -f "$f" ] && source "$f" && return; done }

# GENERAL
fpath=( "$HOME/.zsh/.zfunctions" $fpath )
export EDITOR='vim'
export LESS=" -R "
export LANG=en_US.UTF-8
export PATH="$HOME/.bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# BREW
_is_macos && [ -d "/opt/homebrew/bin" ] && export PATH="/opt/homebrew/bin:$PATH"
export HOMEBREW_NO_INSECURE_REDIRECT=1
export HOMEBREW_CASK_OPTS=--require-sha
export HOMEBREW_USE_INTERNAL_API=true

# FZF
export FZF_DEFAULT_OPTS="--height 50% --min-height 30 --border --ansi --color light"

# GO
export GOPATH=$HOME/work/go
export PATH=$GOPATH/bin:$PATH

# GOOGLE CLOUD SDK (lazy-loaded)
gcloud() {
  unset -f gcloud gsutil bq
  [ -f "$HOME/.google-cloud-sdk/path.zsh.inc" ] && . "$HOME/.google-cloud-sdk/path.zsh.inc"
  [ -f "$HOME/.google-cloud-sdk/completion.zsh.inc" ] && . "$HOME/.google-cloud-sdk/completion.zsh.inc"
  gcloud "$@"
}
gsutil() { gcloud; gsutil "$@"; }
bq() { gcloud; bq "$@"; }

# NODE
export PATH="/usr/local/bin/node:$PATH"

# PIPX
export PATH="$HOME/.local/bin:$PATH"

# PYTHON
if [ -f "$HOME/.poetry/env" ]; then source "$HOME/.poetry/env"; fi

# SUBLIME TEXT
_is_macos && export PATH="/Applications/Sublime Text.app/Contents/SharedSupport/bin:$PATH"

# VSCODE
_is_macos && export PATH="$HOME/Applications/Visual Studio Code.app/Contents/Resources/app/bin:$PATH"

# HELM
_is_macos && export PATH="/opt/homebrew/opt/helm@3/bin:$PATH"

# RUST
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env" || [ -d "$HOME/.cargo/bin" ] && export PATH="$HOME/.cargo/bin:$PATH"
