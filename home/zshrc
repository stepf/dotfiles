# HELPER FUNCTIONS (defined in zshenv, available here via zsh load order)

# BREW (macOS only, hardcoded output of: /opt/homebrew/bin/brew shellenv)
if _is_macos; then
  export HOMEBREW_PREFIX="/opt/homebrew"
  export HOMEBREW_CELLAR="/opt/homebrew/Cellar"
  export HOMEBREW_REPOSITORY="/opt/homebrew"
  export PATH="/opt/homebrew/bin:/opt/homebrew/sbin${PATH+:$PATH}"
  [ -z "${MANPATH-}" ] || export MANPATH=":${MANPATH#:}"
  export INFOPATH="/opt/homebrew/share/info:${INFOPATH:-}"
fi

# SETUP
_source_if_exists "$HOME/.zsh_aliases"                       # aliases
_source_if_exists "$HOME/.zsh_functions"                     # functions
_source_if_exists "$HOME/.zsh_conf"                          # configuration and plugins
_source_first "/opt/homebrew/etc/profile.d/z.sh" \
              "/usr/share/z/z.sh" \
              "$HOME/.zsh/z/z.sh"

# PROMPT: starship
_has starship && eval "$(starship init zsh)"

# Sync tmux theme on shell start/reload:
#   macOS -> follow system appearance
#   else  -> re-apply the last theme set via tmux-dark/tmux-light; on a fresh
#            server, autodetect from the terminal background (OSC 11)
[[ -n "$TMUX" ]] && {
  if _is_macos; then
    theme=$([[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]] && echo dark || echo light)
    tmux set-option -g @theme "$theme"   # records the system choice
  else
    theme=$(tmux show-option -gqv @theme 2>/dev/null)
    if [[ -z "$theme" ]]; then
      theme=$(_terminal-bg-theme)
      # persist only a real answer: a silent terminal (e.g. no client attached
      # yet, or one that ignores OSC 11) falls back to dark below but stays
      # re-detectable
      [[ -n "$theme" ]] && tmux set-option -g @theme "$theme"
    fi
  fi
  tmux source-file ~/.tmux-"${theme:-dark}".conf
}

# SYNTAX HIGHLIGHTING (must load last, after all other ZLE/prompt setup)
#   macOS -> zsh-patina; else -> zsh-syntax-highlighting plugin fallback
if _has zsh-patina; then
  eval "$(zsh-patina activate)"
else
  _source_first "/usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
                "/usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi
