#!/usr/bin/env zsh

# HELPER FUNCTIONS
function _has {
  hash "${1}" 2> /dev/null
}

function _source_if_exists {
  [ -f "${1}" ] && source "${1}" "${2}"
}

# BREW
eval "$(/opt/homebrew/bin/brew shellenv)"

# SETUP
_source_if_exists "$HOME/.zsh_aliases"                       # aliases
_source_if_exists "$HOME/.zshenv"                            # env
_source_if_exists "$HOME/.zsh_functions"                     # functions
_source_if_exists "$HOME/.zsh_conf"                          # configuration and plugins
_source_if_exists "$(brew --prefix)/etc/profile.d/z.sh"      # z

# PROMPT: starship
eval "$(starship init zsh)"

# AUTO THEME SWITCHING: dark-notify for tmux
# Watches macOS appearance and sources ~/.tmux-{light,dark}.conf when it changes
if _has dark-notify && _has tmux; then
  dark-notify -c 'tmux source-file ~/.tmux-$(dark-notify --exit).conf' &
fi
